# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# URL of your Express API server
VITE_API_URL=http://localhost:3001/api

# ─── Backend (Express — used in server/.env) ──────────────────────────────────
# Oracle MySQL connection
DB_HOST=your-oracle-mysql-host.oraclecloud.com
DB_PORT=3306
DB_USER=stream_connect_user
DB_PASSWORD=your_mysql_password
DB_NAME=stream_connect

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# TOTP encryption key — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=your_totp_encryption_key_here

# AES-256-GCM key for service credential encryption — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=your_credentials_encryption_key_here

# SMTP config for password reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@streamconnect.online

# Server port
PORT=3001

# CORS — set to your frontend domain in production
CORS_ORIGIN=https://streamconnect.online
